# Keep the build context small and never bake secrets/data into the image.
.git
.gitignore
.venv
venv
__pycache__
*.pyc
.pytest_cache

# Local data & secrets — mounted as a volume at runtime instead.
data/
.env
credentials.json
token.json

# Generated resumes
resumes/
*.docx
*.pdf

# Docs/dev files not needed in the image
README.md
SPEC.md
*:Zone.Identifier
